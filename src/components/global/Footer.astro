---
// Assets
import Logo from "@/components/assets/Logo.astro";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const links = [
  { label: "Services", href: "/services" },
  { label: "Products", href: "/products" },
  { label: "Contact", href: "/contact" },
  { label: "Privacy Policy", href: "/privacy" },
  { label: "Terms of Service", href: "/terms" },
  { label: "SMS Consent", href: "/consent" },
];
---

<footer>
  <Wrapper class="py-20">
    <a href="/">
      <Logo
        class="h-16 text-white ease-in-out transform"
      />
    </a>
    <div class="mt-10 grid gap-8 border-y border-base-800 py-8 lg:grid-cols-[1.2fr_0.8fr]">
      <div>
        <Text tag="h2" variant="displayXS" class="text-white font-display">
          Clockwork Ideas
        </Text>
        <Text tag="p" variant="textSM" class="mt-3 max-w-xl text-base-400">
          AI automation, customer communication, scheduling, workflow
          automation, and business integration services for small and medium
          businesses.
        </Text>
      </div>
      <div class="space-y-2 text-sm text-base-300">
        <p>
          Website:
          <a
            class="text-accent-300 hover:text-white"
            href="https://www.clockworkideas.com"
            >https://www.clockworkideas.com</a
          >
        </p>
        <p>
          Email:
          <a
            class="text-accent-300 hover:text-white"
            href="mailto:john.dahle@clockworkideas.com"
            >john.dahle@clockworkideas.com</a
          >
        </p>
        <p>
          Phone:
          <a class="text-accent-300 hover:text-white" href="tel:+12059366943"
            >(205) 936-6943</a
          >
        </p>
      </div>
    </div>
    <nav
      class="flex flex-col mt-8 gap-y-2 lg:gap-8 md:flex-row md:flex-wrap"
    >
      {
        links.map((link) => (
          <a
            class="relative -my-2 -mx-3 rounded-lg px-3 py-2 text-sm text-base-300 transition-colors delay-150 hover:text-white hover:delay-[0ms] hover:bg-base-900"
            href={link.href}
          >
            <span class="relative z-10">{link.label}</span>
          </a>
        ))
      }
    </nav>
    <div class="pb-12 mt-16 border-base-800">
      <Text tag="p" variant="textSM" class="text-base-300">
        © Copyright <span>2026</span> Clockwork Ideas. All rights reserved.
      </Text>
    </div>
  </Wrapper>
</footer>
