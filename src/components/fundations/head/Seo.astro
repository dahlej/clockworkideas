---
import { AstroSeo } from "@lexingtonthemes/seo";
---

<AstroSeo
  title="Clockwork Ideas"
  description="AI automation, customer communication, scheduling, workflow automation, and business integration services for small and medium businesses."
  canonical="https://www.clockworkideas.com/"
  openGraph={{
    url: "https://www.clockworkideas.com/",
    title: "Clockwork Ideas",
    description:
      "AI automation, customer communication, scheduling, workflow automation, and business integration services for small and medium businesses.",
    site_name: "Clockwork Ideas",
    type: "website",
    locale: "en_US",
  }}
  twitter={{
    cardType: "summary_large_image",
  }}
/>

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content="https://www.clockworkideas.com/" />
<meta property="og:title" content="Clockwork Ideas" />
<meta
  property="og:description"
  content="AI automation, customer communication, scheduling, workflow automation, and business integration services."
/>

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content="https://www.clockworkideas.com/" />
<meta property="twitter:title" content="Clockwork Ideas" />
<meta
  property="twitter:description"
  content="AI automation, customer communication, scheduling, workflow automation, and business integration services."
/>

<!-- Canonical URL -->
<link rel="canonical" href="https://www.clockworkideas.com/" />

<!-- Additional SEO -->
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />
