---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<section>
  <Wrapper variant="standard" class="pb-12 pt-48">
    <div
      class="mx-auto text-center"
      data-aos="fade-down"
      data-aos-duration="1500"
    >
      <Text tag="h1" variant="displayXL" class="text-white font-display">
        Clockwork Ideas<span class="md:block text-base-400">
          AI automation for small business operations.</span
        >
      </Text>
      <Text
        tag="p"
        variant="textLG"
        class="mx-auto mt-6 max-w-3xl text-base-300 text-balance"
      >
        We provide AI automation, customer communication, scheduling, workflow
        automation, and business integration services for small and medium
        businesses.
      </Text>
      <div class="flex flex-wrap justify-center gap-3 mt-10">
        <Button href="/services" size="lg" variant="accent">Explore services</Button>
        <Button href="/contact" size="lg" variant="muted">Contact us</Button>
      </div>
    </div>
  </Wrapper>
</section>
