---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Data
const items = [
  "AI Agents",
  "Workflow automation",
  "AI Assisted operations",
  "Team training",
  "Customer support systems",
  "Lead intake",
  "Scheduling workflows",
  "Internal tools",
  "CRM handoffs",
  "Email triage",
  "Knowledge bases",
  "Process mapping",
  "Prompt workflows",
  "Human review steps",
  "Reporting automations",
  "Calendar actions",
];

const serviceCards = [
  {
    title: "AI Agents",
    description:
      "Custom agents for support, intake, routing, follow-up, and internal workflows.",
  },
  {
    title: "AI Assisted Workflow Automation",
    description:
      "Tool-connected automations that reduce manual handoffs while keeping human review where it matters.",
  },
  {
    title: "Customer Communication",
    description:
      "SMS, email, support, appointment, invoice, and operational notification workflows.",
  },
  {
    title: "Training",
    description:
      "Practical team training for AI usage, prompt workflows, review habits, and automation upkeep.",
  },
];
---

<section id="services" class="scroll-mt-24">
  <Wrapper variant="standard" class="py-24">
    <div data-aos="fade-up" data-aos-duration="2000">
      <Text tag="h3" variant="displayMD" class="text-white font-display">
        AI enablement for small teams,<span class="md:block text-base-400">
          built around real workflows</span
        >
      </Text>
      <div class="flex mt-12">
        <Button
          href="/services"
          size="lg"
          variant="muted"
          title="#_"
          aria-label="#_">Explore services</Button
        >
      </div>
    </div>
    <ul
      class="grid grid-cols-2 gap-4 py-6 mt-12 sm:grid-cols-2 order-y border-base-800 md:grid-cols-4"
    >
      {
        items.map((item) => (
          <li>
            <Text
              tag="p"
              variant="textBase"
              class="flex items-center gap-2 text-base-300"
            >
              <svg
                width="15"
                height="15"
                viewBox="0 0 15 15"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M11.4669 3.72684C11.7558 3.91574 11.8369 4.30308 11.648 4.59198L7.39799 11.092C7.29783 11.2452 7.13556 11.3467 6.95402 11.3699C6.77247 11.3931 6.58989 11.3355 6.45446 11.2124L3.70446 8.71241C3.44905 8.48022 3.43023 8.08494 3.66242 7.82953C3.89461 7.57412 4.28989 7.55529 4.5453 7.78749L6.75292 9.79441L10.6018 3.90792C10.7907 3.61902 11.178 3.53795 11.4669 3.72684Z"
                  fill="currentColor"
                  fill-rule="evenodd"
                  clip-rule="evenodd"
                />
              </svg>{" "}
              {item}
            </Text>
          </li>
        ))
      }
    </ul>

    <div class="grid gap-6 mt-8 border-y border-base-800 py-8 md:grid-cols-2">
      {
        serviceCards.map((service) => (
          <article class="border-t border-base-800 pt-5">
            <Text
              tag="h3"
              variant="textLG"
              class="font-medium text-white"
            >
              {service.title}
            </Text>
            <Text
              tag="p"
              variant="textSM"
              class="mt-3 leading-6 text-base-400"
            >
              {service.description}
            </Text>
          </article>
        ))
      }
    </div>
  </Wrapper>
</section>
