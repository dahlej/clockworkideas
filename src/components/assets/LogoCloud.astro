---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const capabilities = [
  "AI agents",
  "Workflow automation",
  "Customer communication",
  "Scheduling systems",
];
---

<section>
  <Wrapper variant="standard" class="py-24">
    <div
      class="grid grid-cols-1 py-12 items-center border-y md:grid-cols-[max-content_max-content] border-base-800 gap-8 md:gap-12 justify-center"
    >
      <div class="max-w-48 md:max-w-56">
        <Text tag="p" variant="textXS" class="text-base-300 text-balance">
          Clockwork Ideas builds practical automation systems for small business operations.
        </Text>
      </div>
      <div>
        <div class="flex flex-wrap items-center justify-center gap-3">
          {
            capabilities.map((capability) => (
              <span
                class="rounded-full border border-base-700 bg-base-950/70 px-4 py-2 text-sm text-base-200"
              >
                {capability}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </Wrapper>
</section>
