---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const consentText =
  "By submitting this form, you agree to receive SMS messages from Clockwork Ideas related to appointments, invoices, service updates, customer support, and operational notifications. Message and data rates may apply. Message frequency may vary. Reply STOP to opt out. Reply HELP for assistance.";
const registrationWebhookUrl =
  import.meta.env.REGISTRATION_WEBHOOK_URL ??
  "https://clockworkideas.app.n8n.cloud/webhook-test/connect/register";
---

<BaseLayout>
  <section class="relative overflow-hidden pt-36 pb-20 lg:pt-40 lg:pb-24">
    <Wrapper
      variant="standard"
      class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start"
    >
      <div>
        <Text
          tag="p"
          variant="textSM"
          class="font-medium uppercase tracking-[0.18em] text-accent-300"
        >
          SMS Consent
        </Text>
        <Text
          data-aos="fade-up"
          data-aos-duration="1500"
          tag="h1"
          variant="displayLG"
          class="mt-5 text-white font-display text-balance"
        >
          Clockwork Ideas SMS Consent
        </Text>
        <Text tag="p" variant="textBase" class="mt-5 max-w-xl text-base-300">
          Use this form to opt in to service-related SMS messages from
          Clockwork Ideas.
        </Text>

        <div class="mt-8 space-y-3 border-y border-base-800 py-6 text-sm text-base-300">
          <p>Business name: Clockwork Ideas</p>
          <p>
            Email:
            <a class="text-accent-300 hover:text-white" href="mailto:john.dahle@clockworkideas.com"
              >john.dahle@clockworkideas.com</a
            >
          </p>
          <p>
            Phone:
            <a class="text-accent-300 hover:text-white" href="tel:+12059366943"
              >(205) 936-6943</a
            >
          </p>
        </div>

        <Text tag="p" variant="textSM" class="mt-6 max-w-xl leading-6 text-base-400">
          Customers can contact Clockwork Ideas for support and SMS help by
          replying HELP to a Clockwork Ideas message, calling (205) 936-6943, or
          emailing john.dahle@clockworkideas.com.
        </Text>
      </div>

      <form
        action={registrationWebhookUrl}
        method="post"
        class="w-full max-w-xl space-y-5 lg:ml-auto"
      >
        <div>
          <label for="phone" class="block text-sm font-medium text-white">
            Mobile phone number
          </label>
          <input
            id="phone"
            name="phone"
            type="tel"
            autocomplete="tel"
            inputmode="tel"
            required
            placeholder="(555) 555-5555"
            aria-describedby="sms-consent"
            class="block w-full h-12 px-3 py-2 mt-2 border rounded-md appearance-none bg-base-900 border-base-800 focus:bg-base-900 focus:border-accent-300 focus:outline-none focus:ring-accent-300 placeholder-base-500 sm:text-sm text-accent-300 text-lime"
          />
        </div>

        <div class="rounded-xl border border-base-800 bg-base-950/60 p-4">
          <label class="flex gap-3 text-sm leading-6 text-base-300">
            <input
              id="sms-opt-in"
              name="sms_opt_in"
              type="checkbox"
              required
              value="yes"
              class="mt-1 size-4 rounded border-base-700 bg-base-900 text-accent-300 focus:ring-accent-300"
            />
            <span id="sms-consent">{consentText}</span>
          </label>
        </div>

        <input type="hidden" name="business_name" value="Clockwork Ideas" />
        <input type="hidden" name="consent" value={consentText} />
        <input type="hidden" name="source" value="clockwork-ideas-consent-page" />

        <Text tag="p" variant="textSM" class="leading-6 text-base-400">
          Review the
          <a href="/privacy" class="text-accent-300 hover:text-white"
            >Privacy Policy</a
          >
          and
          <a href="/terms" class="text-accent-300 hover:text-white"
            >Terms of Service</a
          >.
        </Text>

        <Button type="submit" size="lg" variant="accent" class="w-full">
          Submit SMS Consent
        </Button>
      </form>
    </Wrapper>
  </section>
</BaseLayout>
