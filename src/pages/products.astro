---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<BaseLayout>
  <section class="relative overflow-hidden">
    <Wrapper
      variant="standard"
      class="flex min-h-dvh flex-col items-center justify-center py-32"
    >
      <div class="mx-auto max-w-2xl text-center">
        <Text
          data-aos="fade-up"
          data-aos-duration="1500"
          tag="h1"
          variant="displayXL"
          class="text-white font-display"
        >
          Products coming soon
        </Text>
        <Text
          tag="p"
          variant="textBase"
          class="mx-auto mt-5 max-w-xl text-base-300 text-balance"
        >
          We are building practical tools for teams that need reliable systems,
          clear workflows, and fewer moving parts.
        </Text>
        <div class="mt-12 flex flex-wrap justify-center gap-3">
          <Button href="/contact" size="lg" variant="accent">Get in touch</Button>
          <Button href="/" size="lg" variant="muted">Back home</Button>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
